# Ignore files inside raw data folder
data/raw/*

# But keep the folder itself
!data/raw/.gitkeep

# Ignore processed data files
data/processed/*

# But keep the folder itself
!data/processed/.gitkeep

# Notebook checkpoints
.ipynb_checkpoints/

# Python cache files
__pycache__/
*.pyc

# OS files
.DS_Store
Thumbs.db

# Environment files
.env
